{
  "name": "dp-master-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run content:generate",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/postbuild.mjs",
    "test": "node --test scripts/*.test.mjs",
    "lint": "oxlint --deny-warnings",
    "content:generate": "node scripts/generate-problems.mjs --write",
    "check:content": "node scripts/generate-problems.mjs --check",
    "check:assets": "node scripts/check-assets.mjs dist",
    "verify": "npm run check:content && npm run test && npm run lint && npm run build && npm run check:assets",
    "preview": "vite preview",
    "deploy:cf": "wrangler deploy",
    "deploy:eo": "npx -y edgeone@1.6.11 pages deploy ./dist -n dpmaster -e production",
    "deploy": "npm run build && npm run deploy:cf && npm run deploy:eo"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "katex": "^0.17.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wrangler": "^4.107.0"
  }
}
