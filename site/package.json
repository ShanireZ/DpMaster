{
  "name": "site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/postbuild.mjs",
    "lint": "oxlint",
    "preview": "vite preview",
    "deploy:cf": "wrangler deploy",
    "deploy:eo": "npx -y edgeone@1.6.11 pages deploy ./dist -n dpmaster -e production",
    "deploy": "npm run build && npm run deploy:cf && npm run deploy:eo"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@gsap/react": "^2.1.2",
    "@types/react-katex": "^3.0.4",
    "gsap": "^3.15.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-katex": "^3.1.0",
    "react-router-dom": "^7.18.1",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wrangler": "^4.107.0"
  }
